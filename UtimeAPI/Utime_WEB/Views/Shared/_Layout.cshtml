@inject Microsoft.AspNetCore.Http.IHttpContextAccessor htAc
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] U-Time</title>

<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" /> 
    <link rel="icon" href="~/option2.png" style="height:20px;width:20px"/>
    <link rel="stylesheet" href="~/Utime_WEB.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link href="~/css/entire.css" rel="stylesheet"/>
    <!-- Calling the Minified Stylesheet ofthe Datepicker plugin-->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.min.css"/>
    <link rel="stylesheet" type="text/css" href="https://bootstraptema.ru/plugins/2017/clockpicker/bootstrap-clockpicker.css"/>


    <link rel="stylesheet" href="~/css/Quartz.css" />

</head>
<body>
    <partial name="_Notification" />
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index"><img src="~/icon3.png" height="60" width="60" class="d-inline-block" /></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (string.IsNullOrEmpty(htAc.HttpContext.Session.GetString("JWT-Token")))
                        {
                            <li class="nav-item" id="select_elem" data-state="cliked">
                                <a class="nav-link " asp-controller="Home" asp-action="Index">Стартовая страница</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item" id="select_elem">
                                <a class="nav-link" asp-controller="Activity" data-state="uncliked" asp-action="IndexActivity" asp-route-regime="0">Сегодня</a>
                            </li>
                        }
                        <li class="nav-item " id="select_elem">
                            <a class="nav-link " asp-controller="Category"  data-state="uncliked" asp-action="IndexCategory">Категории</a>
                        </li>
                        <li class="nav-item" id="select_elem">
                            <a class="nav-link " asp-controller="Activity"  data-state="uncliked" asp-action="IndexActivity" asp-route-regime="1">Задачи</a>
                        </li>
                        <li class="nav-item" id="select_elem">
                            <a class="nav-link " asp-controller="Account"  data-state="uncliked" asp-action="Index">Статистика</a>
                        </li>
                        @if (string.IsNullOrEmpty(htAc.HttpContext.Session.GetString("JWT-Token")))
                        {
                            <li class="nav-item" id="select_elem">
                                <a class="nav-link " asp-controller="UserAuth"  asp-action="Login">Вход</a>
                            </li>
                            <li class="nav-item" id="select_elem">
                                <a class="nav-link" asp-controller="UserAuth"  asp-action="Register">Регистрация</a>
                            </li>

                        }
                        else
                        {
                            <li class="nav-item" id="select_elem">
                                <a class="nav-link " asp-controller="Activity" data-state="uncliked" asp-action="IndexActivity" asp-route-regime="2" >Просрочено</a>
                            </li>
                            <li class="nav-item" id="select-elem">
                                <a class="nav-link" asp-controller="UserAuth"  asp-action="LogOut">Выйти</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>


    <!-- Extension jquery library -->

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>





    <!--  Bootstrap minified bundle script file -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://bootstraptema.ru/plugins/2017/clockpicker/bootstrap-clockpicker.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/js/bootstrap-datepicker.min.js"></script>
    <!-- DATEPICKER minified Script -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
 


    @await RenderSectionAsync("Scripts", required: false)
</body>
</html



