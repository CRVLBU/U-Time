@model Utime_WEB.Models.ViewModels.Category1ViewModel


<partial name="_CreateCategory"/>
<partial name="_UpdateCategory" />
<partial name="_DeleteCategory" />
<div class="row float-end">
    <a class="btn btn-success" id="Create_cat" data-toggle="modal" data-target="#create-modal-cat"><i class="bi bi-plus"></i> Создать</a>
</div>
@if (Model.Categories.Count() > 0)
{
    <div class="row " style="display:flex;justify-content:center">

        @foreach (var item in @Model.Categories)
        {

            <div class="p-4 col-lg-6 col-md-12 ">
                <div class="row" style="border-radius:20px;background-color:white;">
                    <div class="col-4">
                        <a class="label label-info">
                            <i class="bi bi-bag-plus"></i>
                        </a>
                    </div>
                    <div class="col-8">
                        <span style="font-size:calc(var(--vh, 1vh) * 3.5);font-weight:500;" class="text card-title text-black ">@item.CategoryName</span>
                    </div>
                    <div class="row pb-3 pt-2">
                        <div class="col-4 float-end">
                            <span class="text text-black card-title" style="font-weight:500;font-size:calc(var(--vh, 1vh) * 2.5)">Задач: </span>
                            <span class="text  card-title" style="font-weight:500;font-size:calc(var(--vh, 1vh) * 2.5);color:#41d7a7">@item.Amount</span>
                        </div>

                        <div class="col-4">
                            <a class="btn btn-success float-end" id="Update" data-id="@item.ID" data-toggle="modal" data-target="#update-modal-cat" style="width:calc(var(--vw, 1vw) * 7);display:flex;justify-content:center"><i class="bi bi-pencil text-center"></i></a>
                        </div>
                        <div class="col-4">
                            <a class="btn btn-danger float-end" id="Delete" data-id="@item.ID" data-toggle="modal" data-target="#delete-modal-cat" style="width:calc(var(--vw, 1vw) * 6);display:flex;justify-content:center"><i class="bi bi-trash"></i></a>
                        </div>

                    </div>
                </div>
            </div>




        }
    </div>
}
else
{
    <h2 class="text-center" style="padding-left:20px;opacity:50%"><i class="bi bi-x-circle-fill"></i> Пока ничего нет ...</h2>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="text/javascript">

        window.addEventListener('resize', () => {
            // We execute the same script as before
            let new_vh = window.innerHeight * 0.01;
            let new_vw = window.innerWidth * 0.01;

            vh = 7.12 * (7.12 / new_vh);

            console.log(new_vw);

            document.documentElement.style.setProperty('--vw', `${new_vw}px`);
            document.documentElement.style.setProperty('--vh', `${vh}px`);


        });
        $(function () {
            let new_vh = window.innerHeight * 0.01;
            let new_vw = window.innerWidth * 0.01;

            vh = 7.12 * (7.12 / new_vh);

            document.documentElement.style.setProperty('--vh', `${vh}px`);
            document.documentElement.style.setProperty('--vw', `${new_vw}px`);
            $("a#Update").on("click", function (e) {
                console.log($(this).data("id"));
                $("#update-modal-cat").css("background-color", "rgba(0,0,0,0.5)");
                $.post("SetIDCategory", { id: $(this).data("id") });
            });
            $("a#Delete").on("click", function (e) {
                $("#delete-modal-cat").css("background-color", "rgba(0,0,0,0.5)");
                $.post("SetIDCategory", { id: $(this).data("id") });
            });

            $("a#Create").on("click", function (e) {
                $("#delete-modal-cat").css("background-color", "rgba(0,0,0,0.5)");
                $.post("SetIDCategory", { id: $(this).data("id") });
            });
            $("li#select_elem").find(".active").removeClass("active");
            $("li#select_elem:eq(1)").addClass("active");
            $("a#Create_cat").on("click", function () {
                $("#create-modal-cat").css("background-color", "rgba(0,0,0,0.5)");
            });
            
        });   
    </script>

}


