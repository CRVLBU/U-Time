@model Utime_WEB.Models.ViewModels.ActivityGetViewModel



<div class="modal fade" tabindex="-1" role="dialog" id="update-modal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Обновление задачи</h5>

            </div>
            <div class="modal-body">
                <form asp-action="UpdateActivity">
                    <div asp-validation-summary="All" class="text text-danger"></div>
                    <div class="row">

                        <div class="col-12 pb-2">
                            <input asp-for=@Model.activity_update.ActivityName id="upd-name" class="form-control"  />
                            <span asp-validation-for=@Model.activity_update.ActivityName class="text text-danger"></span>
                        </div>

                        <div class="col-12">

                            <div class="form-group">
                                <div id="picker" class="datepicker date input-group">
                                    <input readonly asp-for=@Model.activity_update.DeadLine  id="upd-date" type="text" id="input-date-update" style="background-color:transparent"  class="form-control"  />
                                    <div class="input-group-addon">
                                        <span class="input-group-text px-4"><i class="bi bi-calendar"></i></span>
                                    </div>

                                </div>

                            </div>
                        </div>
                        <div class="col-12">

                            <div class="form-group">
                                <div id="time" class="input-group clockpicker">
                                    <input readonly asp-for=@Model.activity_update.TimeFrame id="upd-time" type="text"  style="background-color:transparent" class="form-control" />
                                    <div class="input-group-addon">
                                        <span class="input-group-text px-4"><i class="bi bi-clock"></i></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 pb-2">
                            <select asp-for=@Model.activity_update.CategoryID asp-items="@Model.categories" id="upd-category" class="form-select">
                                <option disabled selected>---Select new Category---</option>
                            </select>

                            <span asp-validation-for=@Model.activity_update.CategoryID class="text text-danger"></span>
                        </div>
                        <div class="col-12 pb-2">
                            <textarea class="form-control" asp-for=@Model.activity_update.Description style="height:50px" id="upd-description" placeholder="Описание..."></textarea>
                        </div>

                        <div class="row col-12">
                            <div class="col-5">
                                <select id="imp-u" asp-for=@Model.activity_update.Imp class="form-select" style="width:180px;">
                                    <option disabled selected>--Важно--</option>
                                    <option value="0" id="imp-high" data-imp="High">Высокий</option>
                                    <option value="1" id="imp-medium" data-imp="Medium">Средний</option>
                                    <option value="2" id="imp-low" data-imp="Low">Низкий</option>
                                </select>
                            </div>
                            <div class="col-5 pl-3">
                                <select id="urgency-u" asp-for=@Model.activity_update.Urgency class="form-select" style="width:180px;">
                                    <option disabled selected>--Срочно--</option>
                                    <option value="0" id="urgency-high" data-urg="High">Высокий</option>
                                    <option value="1" id="urgency-medium" data-urg="Medium">Средний</option>
                                    <option value="2" id="urgency-low" data-urg="Low">Низкий</option>
                                </select>
                            </div>
                            <div class="col-2">
                                <div class="pt-1">

                                    <span class="text" id="number-u" style="padding-left:24px;font-weight:bold;font-size:x-large;color:#70ccc7"></span>
                                </div>
                            </div>


                        </div>
                        <div class="row col-12">

                            <div class="col-4">
                                <div  style="padding-left:60px">
                                    <span id="dot-1u" class="dot" data-id="" style="background-color:#bbb"></span>

                                </div>


                            </div>

                            <div class="col-4">
                                <div  style="padding-left:100px">
                                    <span id="dot-2u" class="dot" data-id="" style="background-color:#bbb"></span>

                                </div>

                            </div>


                            <div class="col-4">
                              

                                    <span class="text" id="priority-u" style="padding-left:100px;font-weight:bold;font-size:x-large"></span>



                           

                            </div>



                        </div>


                        <div class="float-end pb-2">
                            <input type="submit" class="btn btn-success form-control" style="font-size:18px"></input>
                        </div>

                    </div>

                </form>

            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />









}