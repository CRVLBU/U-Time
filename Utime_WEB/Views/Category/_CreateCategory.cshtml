@model Utime_WEB.Models.ViewModels.Category1ViewModel
<div class="modal fade" tabindex="-1" role="dialog" id="create-modal-cat">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Создание категории</h5>

            </div>
            <div class="modal-body">
                <form asp-action="CreateCategory">
                    <div asp-validation-summary="ModelOnly" class="text text-danger"></div>
                    <div class="row">

                        <div class="col-12 pb-2">
                            <input asp-for=@Model.CreateCategory.CategoryName class="form-control" placeholder="Название..." />
                            <span asp-validation-for=@Model.CreateCategory.CategoryName class="text text-danger"></span>
                        </div>
                        <div class="float-end">
                            <input type="submit" class="btn btn-success form-control"/>
                        </div>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div> 
@section Scripts{
    <partial name="_ValidationScriptsPartial" />
  
}