@model Utime_WEB.Models.DTO.LoginRequestDTO
<div style="display:flex;justify-content:center">


<form method="post" asp-action="Login" style="flex:1 1 auto">
    <div class="p-4 container">
        <div class="row text-center" >
            <h1>Вход</h1>
      </div>
        <div class="row text-center">
            <div asp-validation-summary="All" class="text-danger"></div>

        </div>
        <div class="row">
            <div class="col-6 offset-3 pb-2">
                <input class="form-control" asp-for=@Model.UserName type="text" placeholder="Имя..." />

        </div>
            <div class="col-6 offset-3 pb-2">
              <input class="form-control" id="pass" asp-for=@Model.Password type="text" placeholder="Пароль..." />

                </div>
                <div class="col-1">
                <div class="input-group-append">
                    <span class="input-group-text"  id="show_btn" style="margin-left:-5.5em;height:40px"><i id="depict" class="bi bi-eye-fill"></i></span>
                </div>
                </div>
                
   
            <div class="col-6 offset-3 pb-2">
                <button type="submit" class="form-control btn btn-success " style="font-size:18px">Вход</button>

            </div>

    </div>
    </div>


</form>
</div>
@section Scripts{
    <partial name="_ValidationScriptsPartial"/>
    <script type="text/javascript">
        $(function () {
                        $("li#select_elem").find(".active").removeClass("active");
            $("li#select_elem:eq(4)").addClass("active");
            
            $("#show_btn").on("click", function (e) {
                if ($("#pass").attr("type") == "text"){
                $("#depict").attr("class", "bi bi-eye-fill");
                $("#pass").attr("type", "password");
            }
                        else {
                $("#depict").attr("class", "bi bi-eye-slash-fill");
                $("#pass").attr("type", "text");
            }
        });
        });    
    </script>
}
